#!/usr/bin/env bash
#
# Bid Pilot one-shot native-host installer (generated by the in-browser setup page).
# Installs the messaging host into every Chromium-based browser profile it finds.
#
set -euo pipefail

EXT_ID="__EXTID__"
HOST_NAME="com.bidpilot.host"
DIR="$HOME/.bidpilot"

echo "Bid Pilot installer"
echo "  extension id: $EXT_ID"

NODE_BIN="$(command -v node || true)"
if [ -z "$NODE_BIN" ]; then
  echo "error: 'node' not found on PATH. Install Node.js, then re-run this script." >&2
  exit 1
fi
NODE_DIR="$(dirname "$NODE_BIN")"

CLAUDE_BIN="$(command -v claude || true)"
CLAUDE_DIR=""
if [ -n "$CLAUDE_BIN" ]; then
  CLAUDE_DIR="$(dirname "$CLAUDE_BIN")"
else
  echo "warning: 'claude' not found on PATH. Install Claude Code and log in, or generation will fail." >&2
fi

mkdir -p "$DIR"

# Host script (embedded by the setup page).
cat > "$DIR/host.js" <<'BIDPILOT_HOST_EOF'
__HOSTJS__
BIDPILOT_HOST_EOF

# Launcher hard-codes absolute node/claude paths so it works when the browser is
# launched from the GUI (no shell PATH).
cat > "$DIR/host-launcher.sh" <<LAUNCHER_EOF
#!/usr/bin/env bash
export PATH="$NODE_DIR:$CLAUDE_DIR:\$PATH"
export BIDPILOT_CLAUDE="$CLAUDE_BIN"
exec "$NODE_BIN" "$DIR/host.js" "\$@"
LAUNCHER_EOF

chmod +x "$DIR/host-launcher.sh" "$DIR/host.js"

MANIFEST=$(cat <<MANIFEST_EOF
{
  "name": "$HOST_NAME",
  "description": "Bid Pilot native host",
  "path": "$DIR/host-launcher.sh",
  "type": "stdio",
  "allowed_origins": ["chrome-extension://$EXT_ID/"]
}
MANIFEST_EOF
)

INSTALLED=0
for base in \
  "$HOME/.config/google-chrome" \
  "$HOME/.config/google-chrome-beta" \
  "$HOME/.config/google-chrome-unstable" \
  "$HOME/.config/chromium" \
  "$HOME/.config/BraveSoftware/Brave-Browser" \
  "$HOME/.config/microsoft-edge" \
  "$HOME/.var/app/com.google.Chrome/config/google-chrome" \
  "$HOME/.var/app/com.brave.Browser/config/BraveSoftware/Brave-Browser" \
  "$HOME/Library/Application Support/Google/Chrome" \
  "$HOME/Library/Application Support/Chromium" \
  "$HOME/Library/Application Support/BraveSoftware/Brave-Browser"; do
  if [ -d "$base" ]; then
    mkdir -p "$base/NativeMessagingHosts"
    printf '%s\n' "$MANIFEST" > "$base/NativeMessagingHosts/$HOST_NAME.json"
    echo "installed -> $base/NativeMessagingHosts/$HOST_NAME.json"
    INSTALLED=1
  fi
done

if [ "$INSTALLED" -eq 0 ]; then
  echo "error: no Chromium-based browser profile found under ~/.config or ~/Library." >&2
  exit 1
fi

echo
echo "Done. Return to the Bid Pilot setup tab. If it does not turn green within a few"
echo "seconds, fully quit and reopen your browser (all windows), then reopen the tab."
